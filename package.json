{
  "name": "realtime-collaborative-text-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"vite\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron": "electron electron/main.cjs",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 && electron electron/main.cjs",
    "electron:dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.sora-ichigo.realtime-collaborative-text-editor",
    "productName": "Realtime Collaborative Text Editor",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dir",
      "category": "public.app-category.productivity",
      "identity": null
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "hono": "^4.12.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
